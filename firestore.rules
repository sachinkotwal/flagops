rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId}/governance/{flagKey} {
      allow read, write: if true;
    }
    match /users/{email} {
      allow read, write: if true;
    }
    match /settings/{docId} {
      allow read, write: if true;
    }
  }
}
